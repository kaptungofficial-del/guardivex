{
  "name": "guardivex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev -w @guardivex/web",
    "dev:web": "npm run dev -w @guardivex/web",
    "dev:api": "npm run dev -w @guardivex/api",
    "build": "npm run build -w @guardivex/shared && npm run build -w @guardivex/adapters && npm run build -w @guardivex/policy && npm run build -w @guardivex/queues && npm run build -w @guardivex/database && npm run build -w @guardivex/api && npm run build -w @guardivex/web",
    "build:web": "npm run build -w @guardivex/web",
    "build:api": "npm run build -w @guardivex/api",
    "typecheck": "npm run build",
    "lint": "npm run brand:check && eslint .",
    "brand:check": "node scripts/check-branding.mjs",
    "db:generate": "npm run db:generate -w @guardivex/database",
    "db:migrate": "npm run db:migrate -w @guardivex/database",
    "db:deploy": "npm run db:deploy -w @guardivex/database",
    "db:seed": "npm run db:seed -w @guardivex/database",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "worker:dev": "npm run worker:dev -w @guardivex/api",
    "worker:start": "npm run worker:start -w @guardivex/api",
    "preview": "npm run preview -w @guardivex/web",
    "test": "vitest run"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "path-to-regexp": "8.4.0",
    "lodash": "4.18.0",
    "postcss": "8.5.10",
    "eslint": {
      "minimatch": "3.1.3"
    },
    "@eslint/config-array": {
      "minimatch": "3.1.3"
    },
    "@eslint/eslintrc": {
      "minimatch": "3.1.3"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.7"
    }
  }
}
