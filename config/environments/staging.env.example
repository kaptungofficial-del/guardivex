NODE_ENV=production
APP_ENV=staging
DATABASE_URL=postgresql://staging-user:staging-password@staging-db.internal:5432/guardivex_staging?schema=public
REDIS_URL=redis://default:staging-password@staging-redis.internal:6379
JWT_ACCESS_SECRET=replace-with-staging-secret-from-vault
JWT_REFRESH_SECRET=replace-with-staging-refresh-secret-from-vault
COOKIE_SECRET=replace-with-staging-cookie-secret-from-vault
CORS_ORIGIN=https://staging-app.guardivex.com,https://staging.guardivex.com
VITE_API_URL=https://staging-api.guardivex.com
