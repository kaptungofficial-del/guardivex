{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["react", "react-dom"],
    "paths": {
      "@/*": ["./legacy-open-buffer-shims.d.ts"]
    }
  },
  "include": ["**/*"]
}