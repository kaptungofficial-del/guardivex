{
  "name": "@guardivex/database",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/run-with-root-env.mjs prisma generate && tsc -p tsconfig.json",
    "db:generate": "node ../../scripts/run-with-root-env.mjs prisma generate",
    "db:migrate": "node ../../scripts/run-with-root-env.mjs prisma migrate dev",
    "db:deploy": "node ../../scripts/run-with-root-env.mjs prisma migrate deploy",
    "db:seed": "node ../../scripts/run-with-root-env.mjs tsx prisma/seed.ts",
    "db:studio": "node ../../scripts/run-with-root-env.mjs prisma studio",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
