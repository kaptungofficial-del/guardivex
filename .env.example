# Shared
NODE_ENV=development
APP_ENV=dev

# API
PORT=4000
DATABASE_URL=postgresql://guardivex:guardivex@localhost:5432/guardivex?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-random-refresh-secret
COOKIE_SECRET=replace-with-at-least-32-random-cookie-secret
REFRESH_COOKIE_NAME=guardivex_refresh
CSRF_COOKIE_NAME=guardivex_csrf
CSRF_REQUIRED=true
OTEL_SERVICE_NAME=guardivex-api
CORS_ORIGIN=http://127.0.0.1:5000,http://localhost:5173,http://localhost:5000

# Frontend
VITE_API_URL=http://127.0.0.1:4000

# Postgres Docker
POSTGRES_USER=guardivex
POSTGRES_PASSWORD=guardivex
POSTGRES_DB=guardivex
